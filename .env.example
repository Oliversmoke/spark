# MongoDB
MONGODB_URI=mongodb://localhost:27017/callback

# JWT auth (required) — generate with: openssl rand -base64 32
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3000

# Google Gemini AI
GEMINI_API_KEY=
# Model ID (default: gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# Web Push (generate with: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=ComeBack.ai <onboarding@yourdomain.com>

# Stripe (Phase 9)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRO_PRICE_ID=

# Cron secret (Vercel cron — run hourly: /api/cron?job=reminders)
CRON_SECRET=

# Optional analytics (Plausible)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
