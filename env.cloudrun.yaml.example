# Copy to env.cloudrun.yaml and fill in values (gitignored).
# Used by cloudbuild.yaml and scripts/deploy-cloud-run.sh
#
# After first deploy, set AUTH_URL to your Cloud Run URL:
#   https://YOUR-SERVICE-xxxxx-uc.a.run.app

MONGODB_URI: "mongodb+srv://USER:PASS@cluster.mongodb.net/callback"
AUTH_SECRET: "replace-with-openssl-rand-base64-32"
AUTH_URL: "https://YOUR-SERVICE-REGION.a.run.app"
GEMINI_API_KEY: ""
GEMINI_MODEL: "gemini-2.5-flash"
NEXT_PUBLIC_VAPID_PUBLIC_KEY: ""
VAPID_PRIVATE_KEY: ""
VAPID_SUBJECT: "mailto:you@example.com"
CRON_SECRET: "replace-with-random-secret"
ADMIN_EMAILS: "you@example.com"
STRIPE_SECRET_KEY: ""
STRIPE_WEBHOOK_SECRET: ""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY: ""
STRIPE_PRO_PRICE_ID: ""
RESEND_API_KEY: ""
EMAIL_FROM: "ComeBack.ai <onboarding@yourdomain.com>"
NEXT_PUBLIC_PLAUSIBLE_DOMAIN: ""
